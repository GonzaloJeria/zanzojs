{
  "name": "@zanzojs/react",
  "version": "0.1.0",
  "description": "React bindings for Zanzo ReBAC. O(1) permission checks via ZanzoProvider and useZanzo hook.",
  "keywords": [
    "@zanzojs/core",
    "react",
    "rebac",
    "authorization",
    "permissions",
    "hooks"
  ],
  "homepage": "https://github.com/GonzaloJeria/zanzo",
  "repository": {
    "type": "git",
    "url": "https://github.com/GonzaloJeria/zanzo.git",
    "directory": "packages/react"
  },
  "license": "MIT",
  "author": "Gonzalo Jeria",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:types": "vitest run --typecheck"
  },
  "peerDependencies": {
    "@zanzojs/core": "^0.1.0-beta.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@zanzojs/core": "workspace:*",
    "react": "catalog:",
    "react-dom": "catalog:",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@testing-library/react": "^14.2.1",
    "jsdom": "^24.0.0",
    "tsup": "latest",
    "typescript": "catalog:",
    "vitest": "latest"
  }
}
