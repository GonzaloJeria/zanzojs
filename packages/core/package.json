{
  "name": "@zanzojs/core",
  "version": "0.3.0",
  "description": "Isomorphic ReBAC Authorization for the Modern Web. Inspired by Google Zanzibar.",
  "keywords": [
    "rebac",
    "authorization",
    "permissions",
    "zanzibar",
    "typescript",
    "access-control",
    "zero-dependencies"
  ],
  "homepage": "https://github.com/GonzaloJeria/zanzo",
  "repository": {
    "type": "git",
    "url": "https://github.com/GonzaloJeria/zanzo.git",
    "directory": "packages/core"
  },
  "license": "MIT",
  "author": "Gonzalo Jeria",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "bench": "tsx benchmarks/index.bench.ts",
    "test:watch": "vitest",
    "test:types": "vitest run --typecheck",
    "format": "biome format --write .",
    "lint": "biome lint --write .",
    "check": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "tsup": "^8.3.5",
    "tsx": "^4.19.3",
    "typescript": "catalog:",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18"
  }
}
