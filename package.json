{
  "name": "zanzo-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=20.0"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "bench": "pnpm --filter @zanzojs/core bench",
    "dev": "turbo run dev",
    "test:types": "turbo run test:types",
    "format": "turbo run format",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "dev:test": "pnpm --filter test-app dev",
    "cli": "node packages/cli/dist/index.js"
  },
  "devDependencies": {
    "turbo": "latest",
    "@changesets/cli": "latest"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "es5-ext",
      "esbuild"
    ]
  }
}
